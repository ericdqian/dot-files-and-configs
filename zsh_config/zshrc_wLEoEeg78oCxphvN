source ~/.general_zsh_config
eval "$(/opt/homebrew/bin/brew shellenv)"
export PATH="$PATH:/opt/nvim-macos-arm64/bin"

. "$HOME/.local/bin/env"
eval "$(fnm env --use-on-cd --shell zsh)"

# AWS SSO helper alias
alias aws-sso-refresh='aws sso login --sso-session default'

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/ericqian/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/ericqian/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/ericqian/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/ericqian/google-cloud-sdk/completion.zsh.inc'; fi

