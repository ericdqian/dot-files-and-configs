  // "vscode-neovim.neovimExecutablePaths.darwin": "/opt/nvim-macos-x86_64/bin/nvim",
  "vscode-neovim.neovimExecutablePaths.darwin": "/opt/nvim-macos-arm64/bin/nvim",
  "vscode-neovim.neovimInitVimPaths.darwin": "/Users/ericqian/dot-files-and-configs/nvim_config/init.vim",
  "jupyter.askForKernelRestart": false,
  "terraform.languageServer.enable": true,
